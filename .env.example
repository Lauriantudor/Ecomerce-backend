# Rename this to .env and fill with real secrets before running the app
# Keep .env out of git (add to .gitignore) and commit only this file as example

# Database (MySQL/MariaDB)
# Example format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?allowPublicKeyRetrieval=true
DATABASE_URL=mysql://user:password@localhost:3306/my_database?allowPublicKeyRetrieval=true

# JWT secrets
# Use long, unpredictable strings in production
ACCESS_TOKEN_SECRET=change_this_to_a_long_random_secret
REFRESH_TOKEN_SECRET=change_this_to_another_long_random_secret

# Optional runtime settings
#PORT=3000
#NODE_ENV=development
